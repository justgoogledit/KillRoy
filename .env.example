# Kilroy connector config -- copy to .env and fill in real values.
# See CLAUDE.md "Data sources" and Skills/check-connectors/SKILL.md for what each var gates.

# Overmind GraphQL -- edge-authed on Tesla corp network. {fleet} is substituted per-call.
OVERMIND_BASE_URL_TEMPLATE=https://{fleet}.robots.tesla.com/
# Optional -- falls back to a built-in timeout if unset.
OVERMIND_TIMEOUT_SEC=

# AMR Hub (amrtracker) -- local dev instance, unauthenticated in dev mode. Read-only.
AMR_HUB_BASE_URL=http://localhost:5000

# Sonic AMR Master Tracker -- CSV export from SharePoint. Read-only.
# Note: the real path likely contains a space (e.g. "OneDrive - Tesla") -- do not quote it here,
# the parser takes the value verbatim from the first `=` to end of line.
MASTER_TRACKER_CSV_PATH=C:\Users\jocasias\OneDrive - Tesla\Sonic AMR Master Tracker.csv
MASTER_TRACKER_STALE_WARN_HOURS=24

# Microsoft Graph / Planner -- app-registration auth. Read-only.
GRAPH_API_TENANT_ID=
GRAPH_API_CLIENT_ID=
GRAPH_API_CLIENT_SECRET=
# Comma-separated, one or more plan IDs.
PLANNER_PLAN_IDS=
# Optional override -- skips the runtime GET /me resolution.
GRAPH_API_USER_OBJECT_ID=

# Playwright browser automation -- used only by Skills/confluence-daily-status
# to click through Confluence's native edit UI (specifically to uncheck "Notify
# watchers", a control the Confluence MCP tool has no API equivalent for).
# Point this at a DEDICATED secondary Edge profile that Jordan signs into once
# (so Tesla SSO cookies are already there -- no scripted login needed), NOT at
# his actual daily-driver profile. Reason: Chromium refuses a second
# --user-data-dir launch against a profile that's already open in a running
# browser window, and Jordan's daily-driver profile is open essentially all
# day -- pointing this var at it would fail almost every run. A separate,
# rarely-closed profile used only for this automation avoids that entirely
# while still being a real, already-authenticated session (not a throwaway
# profile that would just hit a login wall).
PLAYWRIGHT_BROWSER_CHANNEL=msedge
PLAYWRIGHT_USER_DATA_DIR=
# NOTE: headed-vs-headless is NOT actually read from this var -- @playwright/mcp
# takes it as a CLI flag, not an env var. This line is a documented DECISION
# RECORD, not live config: the real switch is whether "--headless" appears in
# .mcp.json's playwright args. It's deliberately omitted there today (headed
# default) because this skill posts to a page Jordan's whole team can see,
# under his name, so the run stays visible on screen. Do not add "--headless"
# to .mcp.json without re-reading Skills/confluence-daily-status/SKILL.md's
# rationale first -- and if you do, update this value to stay truthful.
PLAYWRIGHT_HEADLESS=false

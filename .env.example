# Overmind GraphQL -- edge-enforced auth on corp network
# (no bearer needed on-corp; off-corp will fail loud, expected)
OVERMIND_BASE_URL_TEMPLATE=https://{fleet}.robots.tesla.com
OVERMIND_TIMEOUT_SEC=15

# AMR Hub (local amrtracker instance)
# Dev mode is unauthenticated (amrtracker/backend/src/middleware/auth.ts:9 --
# skips JWT validation when AZURE_TENANT_ID/CLIENT_ID unset). Point Kilroy at
# your locally-running amrtracker on :5000.
AMR_HUB_BASE_URL=http://localhost:5000

# Master Tracker CSV export -- authoritative upstream that amrtracker mirrors.
# Export from SharePoint xlsx to CSV, drop it at a known local path, Kilroy reads it.
# Graph API auto-fetch is Phase 2.
MASTER_TRACKER_CSV_PATH=C:/Users/jocasias/OneDrive - Tesla/AMR TRACKER/master-tracker.csv

# CSV freshness threshold -- fleet-commissioning-handoff warns in the package
# when the CSV's mtime is older than this many hours.
MASTER_TRACKER_STALE_WARN_HOURS=24

# Microsoft Graph API (Planner/To Do) -- standard app registration credentials.
# Same auth family as amrtracker's Phase-2 SharePoint plan (mirrors
# GRAPH_API_CLIENT_SECRET from that design). Used to pull Jordan's due-today
# Planner tasks in run-daily-workflow's morning phase. Read-only for v1 --
# Kilroy never writes back to Planner.
GRAPH_API_TENANT_ID=
GRAPH_API_CLIENT_ID=
GRAPH_API_CLIENT_SECRET=

# Planner plan(s) to pull from -- comma-separated, supports one or many since
# Jordan hasn't pinned down whether his tasks live in a single plan or are
# spread across several. e.g. PLANNER_PLAN_IDS=abc123,def456
PLANNER_PLAN_IDS=

# Optional override for Jordan's Azure AD object ID (a GUID). Real Planner
# "assignments" are keyed by AAD object GUIDs, not a plain assignee field, so
# filtering to "my assigned tasks" requires knowing this ID. Default behavior:
# Kilroy resolves it at runtime via GET /me. Only set this if /me isn't
# available or desired.
GRAPH_API_USER_OBJECT_ID=
